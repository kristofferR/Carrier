{
  "name": "carrier",
  "version": "1.2.0",
  "description": "A tiny, distraction-free desktop client for Facebook Messenger, built with Tauri.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "tauri": "tauri",
    "icon": "tauri icon",
    "build:inject": "bun inject/build.ts",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsgo --noEmit -p tsconfig.json && tsgo --noEmit -p tsconfig.test.json",
    "check": "bun run lint && bun run typecheck && bun test && bun run build:inject"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@tauri-apps/cli": "^2",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260706.1",
    "esbuild": "^0.28.1",
    "tauri-plugin-mcp-server": "0.1.0",
    "typescript": "^6.0.3"
  }
}
