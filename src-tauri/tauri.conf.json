{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Carrier",
  "version": "1.6.0",
  "identifier": "io.github.kristofferr.carrier",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app",
      "nsis",
      "deb",
      "rpm",
      "appimage"
    ],
    "publisher": "kristofferR",
    "category": "SocialNetworking",
    "shortDescription": "Distraction-free Messenger desktop client",
    "longDescription": "Carrier wraps the Facebook Messenger web app in a tiny native window and strips away the surrounding Facebook chrome \u2014 no Feed, no Reels, no Marketplace. Built with Tauri.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    },
    "linux": {
      "deb": {
        "desktopTemplate": "linux/carrier.desktop.hbs",
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ],
        "files": {
          "/usr/share/metainfo/io.github.kristofferr.carrier.metainfo.xml": "linux/io.github.kristofferr.carrier.metainfo.xml"
        },
        "section": "net"
      },
      "rpm": {
        "desktopTemplate": "linux/carrier.desktop.hbs",
        "depends": [
          "webkit2gtk4.1",
          "gtk3"
        ],
        "files": {
          "/usr/share/metainfo/io.github.kristofferr.carrier.metainfo.xml": "linux/io.github.kristofferr.carrier.metainfo.xml"
        }
      },
      "appimage": {
        "bundleMediaFramework": true,
        "files": {
          "/usr/share/metainfo/io.github.kristofferr.carrier.metainfo.xml": "linux/io.github.kristofferr.carrier.metainfo.xml"
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kristofferR/carrier/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyNUU2MkMzRUU2MTdGMkQKUldRdGYySHV3MkplWXFtdnR2aUV6YVQ2V3NQRWwwNC9kcE43MmZSSnQwMFgwcEM4SHgrS3NPeGkK"
    }
  }
}
