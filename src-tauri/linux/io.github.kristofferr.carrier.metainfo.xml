<component type="desktop-application">
  <id>io.github.kristofferr.carrier</id>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>Carrier</name>
  <summary>A focused desktop client for Facebook Messenger</summary>
  <description>
    <p>
      Carrier wraps Messenger in a small native desktop window and removes the
      surrounding Facebook feed, Reels, Marketplace, and other distractions.
    </p>
    <p>
      It provides native notifications, unread indicators, keyboard shortcuts,
      system theme integration, privacy controls, and a system tray.
    </p>
  </description>
  <launchable type="desktop-id">Carrier.desktop</launchable>
  <provides>
    <binary>carrier</binary>
  </provides>
  <url type="homepage">https://kristofferr.github.io/Carrier/</url>
